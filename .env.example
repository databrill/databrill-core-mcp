# ── Single-workspace mode ──────────────────────────────────────────────────
# Direct Postgres connection to the client's target DB. Used when DATABRILL_CONFIG
# is NOT set.
POSTGRES_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# ── Multi-workspace mode ────────────────────────────────────────────────────
# Point at a JSON config (see databrill.config.example.json) to serve several
# client workspaces from one server. The config's ${VAR} placeholders are
# expanded from the variables below, so connection secrets stay here in .env.
# DATABRILL_CONFIG=./databrill.config.json
# WORKSPACE_A_POSTGRES_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
# WORKSPACE_B_POSTGRES_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
